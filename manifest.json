{
  "manifest_version": 3,
  "name": "StreetPeek",
  "version": "1.0.0",
  "description": "View approximate Street View, nearby amenities, and public crime data for supported locations on rental listings.",
  "permissions": [],
  "host_permissions": [
    "https://nominatim.openstreetmap.org/*",
    "https://overpass-api.de/*",
    "https://data.cityofnewyork.us/*",
    "https://data.lacity.org/*",
    "https://data.cityofchicago.org/*",
    "https://www.dallasopendata.com/*",
    "https://phl.carto.com/*",
    "https://data.sfgov.org/*",
    "https://data.seattle.gov/*",
    "https://maps2.dcgis.dc.gov/*",
    "https://services1.arcgis.com/*",
    "https://data.police.uk/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.airbnb.com/rooms/*", "https://www.airbnb.co.uk/rooms/*", "https://www.airbnb.ca/rooms/*", "https://www.airbnb.com.au/rooms/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
